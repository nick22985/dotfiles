#!/usr/bin/env bash
set -uo pipefail

AUDIT_LOG=/workspace/.sbx/audit.log

# Resolve real bun via mise (project mise.toml overrides global mise.toml).
REAL=""
if command -v mise >/dev/null 2>&1; then
    if mise_bun="$(mise which bun 2>/dev/null)" && [ -n "$mise_bun" ]; then
        REAL="$mise_bun"
    fi
fi
if [ -z "$REAL" ]; then
    echo "sbx: no bun found — add 'bun' to mise.toml or .tool-versions." >&2
    exit 127
fi

audit() {
    mkdir -p /workspace/.sbx 2>/dev/null || return 0
    printf '%s\t%s\tbun %s\n' "$(date -Iseconds)" "$PWD" "$*" >> "$AUDIT_LOG" 2>/dev/null || true
}

case "${1:-}" in
    i|install|add|update|upgrade|a)
        audit "$@"
        extra=()
        if [ -z "${SBX_RUN_SCRIPTS:-}" ]; then
            case " $* " in
                *' --ignore-scripts '*|*' --trust '*) ;;
                *) extra=(--ignore-scripts)
                   printf 'sbx: bun %s with --ignore-scripts (SBX_RUN_SCRIPTS=1 to enable)\n' "$1" >&2 ;;
            esac
        fi
        if [ "${SBX_MIN_PKG_AGE_DAYS:-7}" -gt 0 ]; then
            case " $* " in
                *' --minimum-release-age '*|*' --minimum-release-age='*) ;;
                *) age_secs=$(( ${SBX_MIN_PKG_AGE_DAYS:-7} * 86400 ))
                   extra+=(--minimum-release-age="$age_secs")
                   printf 'sbx: --minimum-release-age=%ss (require pkg >=%s days old; SBX_MIN_PKG_AGE_DAYS=0 to disable)\n' "$age_secs" "${SBX_MIN_PKG_AGE_DAYS:-7}" >&2 ;;
            esac
        fi
        "$REAL" "$@" "${extra[@]}"
        exit $?
        ;;
    *)
        exec "$REAL" "$@"
        ;;
esac
