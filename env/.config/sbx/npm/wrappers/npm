#!/usr/bin/env bash
set -uo pipefail

AUDIT_LOG=/workspace/.sbx/audit.log

# Resolve real npm via mise (project mise.toml overrides global mise.toml).
REAL=""
if command -v mise >/dev/null 2>&1; then
    if mise_npm="$(mise which npm 2>/dev/null)" && [ -n "$mise_npm" ]; then
        REAL="$mise_npm"
    fi
fi
if [ -z "$REAL" ]; then
    echo "sbx: no npm found — add 'node' to mise.toml or .tool-versions." >&2
    exit 127
fi

audit() {
    mkdir -p /workspace/.sbx 2>/dev/null || return 0
    printf '%s\t%s\tnpm %s\n' "$(date -Iseconds)" "$PWD" "$*" >> "$AUDIT_LOG" 2>/dev/null || true
}

case "${1:-}" in
    i|in|ins|install|isntall|add|ci|update|up|upgrade|rebuild)
        audit "$@"
        extra=()
        if [ -z "${SBX_RUN_SCRIPTS:-}" ]; then
            case " $* " in
                *' --ignore-scripts '*|*' --foreground-scripts '*) ;;
                *) extra=(--ignore-scripts)
                   printf 'sbx: npm install with --ignore-scripts (SBX_RUN_SCRIPTS=1 to enable)\n' >&2 ;;
            esac
        fi
        if [ "${SBX_MIN_PKG_AGE_DAYS:-7}" -gt 0 ] && [ "${1}" != "ci" ]; then
            case " $* " in
                *' --before '*|*' --before='*) ;;
                *) cutoff="$(date -u -d "${SBX_MIN_PKG_AGE_DAYS:-7} days ago" +%Y-%m-%d)"
                   extra+=(--before="$cutoff")
                   printf 'sbx: --before=%s (require pkg >=%s days old; SBX_MIN_PKG_AGE_DAYS=0 to disable)\n' "$cutoff" "${SBX_MIN_PKG_AGE_DAYS:-7}" >&2 ;;
            esac
        fi
        "$REAL" "$@" "${extra[@]}"
        exit $?
        ;;
    *)
        exec "$REAL" "$@"
        ;;
esac
