#!/usr/bin/env bash
set -uo pipefail

REAL=/home/dev/.cargo/bin/cargo.real
AUDIT_LOG=/workspace/.sbx/audit.log

# If the project has a mise config, route to mise's cargo so tool versions
# pin per-project. Falls back to the FROM-image's cargo when no config.
if command -v mise >/dev/null 2>&1; then
    if mise_cargo="$(mise which cargo 2>/dev/null)" && [ -n "$mise_cargo" ]; then
        REAL="$mise_cargo"
    fi
fi

audit() {
    mkdir -p /workspace/.sbx 2>/dev/null || return 0
    printf '%s\t%s\tcargo %s\n' "$(date -Iseconds)" "$PWD" "$*" >> "$AUDIT_LOG" 2>/dev/null || true
}

case "${1:-}" in
    add|update|install|build|fetch|generate-lockfile)
        audit "$@"
        "$REAL" "$@"
        exit $?
        ;;
    *)
        exec "$REAL" "$@"
        ;;
esac
