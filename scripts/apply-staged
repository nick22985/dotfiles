#!/usr/bin/env bash

# apply-staged - Copy git-staged dotfile changes from env/ out to $HOME.
#
# Counterpart to sync-hypr / sync-nvim (which go live -> repo). This goes
# repo -> live, but only for files currently staged in git, so you can
# stage exactly what you want to deploy and run this to push it.
#
# Mapping: env/<rest>  ->  $HOME/<rest>
#
# Usage:
#   scripts/apply-staged              # dry run, list what would change
#   scripts/apply-staged --apply      # actually copy
#   scripts/apply-staged --apply -d   # also propagate staged deletions
#                                     # (rm from $HOME for files git rm'd)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_plan()  { echo -e "${BLUE}[PLAN]${NC} $1"; }

APPLY=0
HANDLE_DELETES=0
for arg in "$@"; do
    case "$arg" in
        --apply|-y) APPLY=1 ;;
        --deletes|-d) HANDLE_DELETES=1 ;;
        -h|--help)
            sed -n '3,16p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) log_error "unknown arg: $arg"; exit 2 ;;
    esac
done

cd "$DOTFILES_DIR"

# Collect staged paths under env/ separately for ACMR (copy) and D (delete).
mapfile -t COPY_FILES < <(git diff --cached --name-only --diff-filter=ACMR -- 'env/*' 'env/**')
mapfile -t DELETE_FILES < <(git diff --cached --name-only --diff-filter=D -- 'env/*' 'env/**')

# Anything staged outside env/ — just inform, don't act.
mapfile -t OUTSIDE_FILES < <(git diff --cached --name-only -- ':!env/*' ':!env/**')

if [[ ${#COPY_FILES[@]} -eq 0 && ${#DELETE_FILES[@]} -eq 0 ]]; then
    log_info "No staged changes under env/ to apply."
    if [[ ${#OUTSIDE_FILES[@]} -gt 0 ]]; then
        log_info "(${#OUTSIDE_FILES[@]} staged file(s) outside env/ — ignored)"
    fi
    exit 0
fi

if [[ ${#OUTSIDE_FILES[@]} -gt 0 ]]; then
    log_warn "Ignoring ${#OUTSIDE_FILES[@]} staged file(s) outside env/:"
    for f in "${OUTSIDE_FILES[@]}"; do echo "    $f"; done
fi

BACKUP_DIR="$DOTFILES_DIR/.backup/apply-staged-$(date +%Y%m%d-%H%M%S)"

map_target() {
    # env/<rest>  ->  $HOME/<rest>
    local src="$1"
    echo "$HOME/${src#env/}"
}

# Plan: copies
for src in "${COPY_FILES[@]}"; do
    [[ -z "$src" ]] && continue
    target="$(map_target "$src")"
    if [[ -e "$target" ]]; then
        log_plan "update  $src -> $target"
    else
        log_plan "create  $src -> $target"
    fi
done

# Plan: deletes
if [[ ${#DELETE_FILES[@]} -gt 0 ]]; then
    if [[ $HANDLE_DELETES -eq 1 ]]; then
        for src in "${DELETE_FILES[@]}"; do
            [[ -z "$src" ]] && continue
            target="$(map_target "$src")"
            if [[ -e "$target" ]]; then
                log_plan "remove  $target"
            else
                log_plan "skip    $target (already gone)"
            fi
        done
    else
        log_info "${#DELETE_FILES[@]} staged deletion(s) under env/ (pass --deletes to also remove from \$HOME):"
        for src in "${DELETE_FILES[@]}"; do echo "    $src"; done
    fi
fi

if [[ $APPLY -eq 0 ]]; then
    echo
    log_info "Dry run. Re-run with --apply to copy the files."
    exit 0
fi

log_info "Backup dir: $BACKUP_DIR"

# Execute: copies
for src in "${COPY_FILES[@]}"; do
    [[ -z "$src" ]] && continue
    target="$(map_target "$src")"
    if [[ -f "$target" ]]; then
        rel="${target#$HOME/}"
        mkdir -p "$BACKUP_DIR/$(dirname "$rel")"
        cp -a "$target" "$BACKUP_DIR/$rel"
    fi
    mkdir -p "$(dirname "$target")"
    cp -a "$src" "$target"
    log_info "wrote   $target"
done

# Execute: deletes (opt-in)
if [[ $HANDLE_DELETES -eq 1 ]]; then
    for src in "${DELETE_FILES[@]}"; do
        [[ -z "$src" ]] && continue
        target="$(map_target "$src")"
        if [[ -f "$target" ]]; then
            rel="${target#$HOME/}"
            mkdir -p "$BACKUP_DIR/$(dirname "$rel")"
            cp -a "$target" "$BACKUP_DIR/$rel"
            rm -f "$target"
            log_info "removed $target"
        fi
    done
fi

log_info "Done. Backup of overwritten/removed files: $BACKUP_DIR"
